//  creates Multiple alien
    @POST
    @Path("alien")
    @Consumes({MediaType.APPLICATION_XML,MediaType.APPLICATION_JSON})
    public List<Alien> createAliens(List<Alien> aliens) {

        for(Alien a : aliens) {
            repo.create(a);
        }

        return aliens;
    }
    
    @PUT
    @Path("updateAlien")
    @Consumes({MediaType.APPLICATION_XML,MediaType.APPLICATION_JSON})
    public Alien updateAliens(Alien a) {
    	if(repo.getAlien(a.getId()) != null) {    		
    		repo.update(a);
    	}
    	else repo.create(a);
        return a;
    }
    @PUT
    @Path("deleteAlien/{id}")
    @Consumes({MediaType.APPLICATION_XML,MediaType.APPLICATION_JSON})
    public Alien deleteAlien(@PathParam("id") int id) {
    	Alien a = repo.getAlien(id);
    	repo.delete(id);
    	return a;
    }
}