package com.khushal.demoWebApp;

import java.util.*;

public class AlienRepository 
{
	List<Alien> aliens ;
	
	public AlienRepository() {
		aliens = new ArrayList<>();
		
		Alien a1 = new Alien();
		a1.setId(101);
		a1.setName("Navin");
		a1.setPoints(60);
		
		Alien a2 = new Alien();
		a2.setId(102);
		a2.setName("Khushal");
		a2.setPoints(99);
		
		aliens.add(a1);
		aliens.add(a2);
	}
	
	public List<Alien> getAliens(){
		return aliens;
	}
	
	public Alien getAlien(int id) {
		Alien a1 = null;
		
		for(Alien a: aliens) {
			if(a.getId() == id) {
				a1 = a;
			}
		}
		
		return a1;
	}
	
	

}
